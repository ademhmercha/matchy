# Port (Render définit PORT automatiquement)
PORT=5000

# MongoDB Atlas - remplace <db_password> par ton mot de passe
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/matchy?retryWrites=true&w=majority&appName=Cluster0

# Secret pour les sessions (génère une chaîne aléatoire en production)
SESSION_SECRET=change-me-in-production

# URL du frontend (Vercel) - pour CORS et Socket.io
FRONTEND_URL=https://ton-app.vercel.app
